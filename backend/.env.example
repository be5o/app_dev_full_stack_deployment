# Supabase (get these from: Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Set automatically by Railway - do not change
# PORT=3500
